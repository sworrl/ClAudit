#!/usr/bin/env bash
# Directive: every code change bumps __version__. This hook enforces it automatically —
# it auto-increments the patch version on every commit UNLESS the version was already
# changed in this commit (so manual minor/major bumps are respected, not double-bumped).
#
# Enable once per clone:   git config core.hooksPath scripts/githooks
set -e
f="claudit_scan.py"
[ -f "$f" ] || exit 0
cur=$(grep -oE '__version__ = "[0-9]+\.[0-9]+\.[0-9]+"' "$f" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
prev=$(git show HEAD:"$f" 2>/dev/null | grep -oE '__version__ = "[0-9]+\.[0-9]+\.[0-9]+"' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
if [ -n "$cur" ] && [ "$cur" = "$prev" ]; then
  IFS=. read -r a b c <<< "$cur"
  new="$a.$b.$((c + 1))"
  sed -i "s/__version__ = \"$cur\"/__version__ = \"$new\"/" "$f"
  sed -i "s/version-$cur/version-$new/" README.md 2>/dev/null || true
  git add "$f" README.md
  echo "ClAudit: auto-bumped version $cur -> $new"
fi
